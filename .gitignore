**/results/
**/.venv/
**/__pycache__/
*.pyc
.DS_Store
**/node_modules/
**/.next/
**/dist/

# Python lockfiles for skills — kept local, not part of distribution
skills/*/uv.lock
skills/*/pyproject.toml

# Secrets / credentials — prevent accidental commits
.env
.env.*
*.key
*.pem
credentials*.json
*secret*.json
*token*.json
*.zip

# icon-search: commit the small search index, not the heavy render artifact
skills/icon-search/catalog/*.render.json
