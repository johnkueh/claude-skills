#!/usr/bin/env bash
# Wrapper that runs the TS CLI from the skill's own node_modules while preserving the user's cwd.
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Ensure deps are installed (one-time per skill version).
if [ ! -d "$SCRIPT_DIR/node_modules" ]; then
  echo "First run — installing deps for aeo-monitor..." >&2
  if command -v pnpm >/dev/null 2>&1; then
    ( cd "$SCRIPT_DIR" && pnpm install --silent --prod=false )
  elif command -v npm >/dev/null 2>&1; then
    ( cd "$SCRIPT_DIR" && npm install --silent --no-audit --no-fund )
  else
    echo "error: need pnpm or npm to install dependencies for aeo-monitor" >&2
    exit 1
  fi
fi

exec "$SCRIPT_DIR/node_modules/.bin/tsx" "$SCRIPT_DIR/src/cli.ts" "$@"
